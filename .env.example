# OpenRouter API
OPENROUTER_API_KEY=your_api_key_here

# Database
DATABASE_PATH=./language_trainer.db

# LLM Configuration
DEFAULT_MODEL=openai/gpt-3.5-turbo
# or: openai/gpt-4o-mini
# or: anthropic/claude-3-haiku
# or: meta-llama/llama-3.2-3b-instruct:free

# Learning Parameters
TARGET_SUCCESS_RATE=0.70
LLM_TIMEOUT=30

# System Mode
GENERATIVE_MODE=true  # Always true now - all tasks are AI-generated
